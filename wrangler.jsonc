{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mrux-log-console",
  "main": "src/index.js",
  "compatibility_date": "2025-02-04",
  "assets": {
    "directory": "./public"
  },
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "LOG_ROOM",
        "class_name": "LogRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "LogRoom"
      ]
    }
  ]
}